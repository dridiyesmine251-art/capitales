// ══════════════════════════════════════
//  STATE
// ══════════════════════════════════════
let currentContinent = null;
let revCards = [];
let revIndex = 0;
let revErrors = [];
let revRound = 1;
let revCorrectTotal = 0;
let revTotalCards = 0;

let testQueue = [];
let testErrors = [];
let testCorrect = 0;
let testWrong = 0;
let testTotal = 0;
let testWaiting = false;

// ══════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════
function showScreen(id) {
  document.querySelectorAll('#app > div[id^="screen-"]').forEach(s => s.classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}

function goHome() {
  currentContinent = null;
  showScreen('screen-home');
}

function goMode() {
  showScreen('screen-mode');
}

// ══════════════════════════════════════
//  HOME — Continent Grid
// ══════════════════════════════════════
function buildHome() {
  const grid = document.getElementById('continent-grid');
  grid.innerHTML = '';
  for (const [name, pairs] of Object.entries(DATA)) {
    const card = document.createElement('div');
    card.className = 'continent-card';
    card.innerHTML = `
      <span class="continent-emoji">${EMOJIS[name]}</span>
      <div class="continent-name">${name}</div>
      <div class="continent-count">${pairs.length} pays</div>
    `;
    card.onclick = () => selectContinent(name);
    grid.appendChild(card);
  }
}

function selectContinent(name) {
  currentContinent = name;
  document.getElementById('mode-continent-title').textContent = EMOJIS[name] + ' ' + name;
  document.getElementById('mode-continent-count').textContent = DATA[name].length + ' pays à apprendre';
  showScreen('screen-mode');
}

// ══════════════════════════════════════
//  REVISION — Quizlet-style flashcards
// ══════════════════════════════════════
function startRevision() {
  revCards = shuffle([...DATA[currentContinent]]);
  revIndex = 0;
  revErrors = [];
  revRound = 1;
  revCorrectTotal = 0;
  revTotalCards = revCards.length;
  showScreen('screen-revision');
  document.getElementById('flashcard-area').classList.remove('hidden');
  document.getElementById('round-summary').classList.add('hidden');
  document.getElementById('revision-complete').classList.add('hidden');
  showFlashcard();
}

function showFlashcard() {
  const fc = document.getElementById('flashcard');
  fc.classList.remove('flipped');
  document.getElementById('fc-buttons').style.visibility = 'hidden';
  const pair = revCards[revIndex];
  document.getElementById('fc-front-text').textContent = pair[0];
  document.getElementById('fc-back-text').textContent = pair[1];

  const total = revTotalCards;
  const done = revCorrectTotal + revIndex;
  document.getElementById('rev-progress-text').textContent = `${revIndex + 1} / ${revCards.length}`;
  document.getElementById('rev-round-text').textContent = `Vague ${revRound}`;
  document.getElementById('rev-progress-fill').style.width = `${(revCorrectTotal / revTotalCards) * 100}%`;
}

function flipCard() {
  const fc = document.getElementById('flashcard');
  if (!fc.classList.contains('flipped')) {
    fc.classList.add('flipped');
    document.getElementById('fc-buttons').style.visibility = 'visible';
  }
}

function markCorrect() {
  revCorrectTotal++;
  nextFlashcard();
}

function markWrong() {
  revErrors.push(revCards[revIndex]);
  nextFlashcard();
}

function nextFlashcard() {
  revIndex++;
  if (revIndex >= revCards.length) {
    showRoundSummary();
  } else {
    showFlashcard();
  }
}

function showRoundSummary() {
  document.getElementById('flashcard-area').classList.add('hidden');
  document.getElementById('round-summary').classList.remove('hidden');

  const correct = revCards.length - revErrors.length;
  const title = document.getElementById('round-summary-title');
  const desc = document.getElementById('round-summary-desc');
  const errorList = document.getElementById('round-error-list');
  const errorItems = document.getElementById('round-error-items');
  const btn = document.getElementById('round-next-btn');

  if (revErrors.length === 0) {
    // All done!
    document.getElementById('round-summary').classList.add('hidden');
    document.getElementById('revision-complete').classList.remove('hidden');
    document.getElementById('rev-progress-fill').style.width = '100%';
    return;
  }

  title.textContent = `Vague ${revRound} terminée`;
  desc.textContent = `${correct} / ${revCards.length} correct — ${revErrors.length} à revoir`;

  errorList.classList.remove('hidden');
  errorItems.innerHTML = '';
  revErrors.forEach(([country, capital]) => {
    const div = document.createElement('div');
    div.className = 'error-item';
    div.innerHTML = `<span class="country">${country}</span> → <span class="capital">${capital}</span>`;
    errorItems.appendChild(div);
  });

  btn.textContent = `Revoir les ${revErrors.length} erreur${revErrors.length > 1 ? 's' : ''} →`;
}

function nextRound() {
  revRound++;
  revCards = shuffle([...revErrors]);
  revErrors = [];
  revIndex = 0;
  document.getElementById('round-summary').classList.add('hidden');
  document.getElementById('round-error-list').classList.add('hidden');
  document.getElementById('flashcard-area').classList.remove('hidden');
  showFlashcard();
}

// ══════════════════════════════════════
//  TEST MODE
// ══════════════════════════════════════
function startTest() {
  testQueue = shuffle([...DATA[currentContinent]]);
  testErrors = [];
  testCorrect = 0;
  testWrong = 0;
  testTotal = testQueue.length;
  testWaiting = false;
  showScreen('screen-test');
  updateTestUI();
  showTestQuestion();
}

function showTestQuestion() {
  if (testQueue.length === 0) {
    if (testErrors.length === 0) {
      // PERFECT — Fireworks!
      launchFireworks();
      showCongrats();
    } else {
      // Restart with errors
      testQueue = shuffle([...testErrors]);
      testErrors = [];
      testTotal = testQueue.length;
      testCorrect = 0;
      testWrong = 0;
      updateTestUI();
      showTestQuestion();
    }
    return;
  }
  const pair = testQueue[0];
  document.getElementById('test-country-name').textContent = pair[0];
  document.getElementById('test-input').value = '';
  document.getElementById('test-input').className = 'test-input';
  document.getElementById('test-feedback').textContent = '';
  document.getElementById('test-feedback').className = 'test-feedback';
  document.getElementById('test-input').focus();
  testWaiting = false;
}

function submitTestAnswer() {
  if (testWaiting) {
    // Move to next
    testQueue.shift();
    testWaiting = false;
    showTestQuestion();
    updateTestUI();
    return;
  }
  const input = document.getElementById('test-input');
  const feedback = document.getElementById('test-feedback');
  const answer = input.value.trim();
  if (!answer) return;

  const pair = testQueue[0];
  const correct = pair[1];

  if (normalize(answer) === normalize(correct)) {
    input.className = 'test-input correct-input';
    feedback.textContent = '✓ Correct !';
    feedback.className = 'test-feedback correct-fb';
    testCorrect++;
  } else {
    input.className = 'test-input wrong-input';
    feedback.textContent = `✗ La réponse était : ${correct}`;
    feedback.className = 'test-feedback wrong-fb';
    testWrong++;
    testErrors.push(pair);
  }

  testWaiting = true;
  document.getElementById('test-submit-btn').textContent = 'Suivant →';
  updateTestUI();

  // Auto-advance or let user click
  setTimeout(() => {
    document.getElementById('test-submit-btn').textContent = 'OK';
  }, 100);
}

function updateTestUI() {
  const done = testCorrect + testWrong;
  const left = testQueue.length - (testWaiting ? 1 : 0);
  document.getElementById('test-progress-text').textContent = `${done} / ${testTotal}`;
  document.getElementById('test-remaining-text').textContent = testErrors.length > 0 ? `⚠ ${testErrors.length} erreur(s)` : '';
  document.getElementById('test-progress-fill').style.width = `${(done / testTotal) * 100}%`;
  document.getElementById('test-correct-count').textContent = testCorrect;
  document.getElementById('test-wrong-count').textContent = testWrong;
  document.getElementById('test-left-count').textContent = left;
}

// Key handler
document.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    const testScreen = document.getElementById('screen-test');
    if (!testScreen.classList.contains('hidden')) {
      submitTestAnswer();
    }
  }
});

// ══════════════════════════════════════
//  FIREWORKS
// ══════════════════════════════════════
function launchFireworks() {
  const canvas = document.getElementById('fireworksCanvas');
  canvas.classList.remove('hidden');
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  const particles = [];
  const colors = ['#ff6584','#6c63ff','#43e97b','#ffd700','#ff9a00','#00d2ff','#ff00ff','#ffffff'];
  let animFrame;

  function createBurst(x, y) {
    const count = 80 + Math.random() * 40;
    for (let i = 0; i < count; i++) {
      const angle = Math.random() * Math.PI * 2;
      const speed = 2 + Math.random() * 6;
      particles.push({
        x, y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        life: 1,
        decay: 0.008 + Math.random() * 0.015,
        color: colors[Math.floor(Math.random() * colors.length)],
        size: 2 + Math.random() * 3,
        gravity: 0.04 + Math.random() * 0.02
      });
    }
  }

  // Launch several bursts
  for (let i = 0; i < 5; i++) {
    setTimeout(() => {
      createBurst(
        canvas.width * (0.2 + Math.random() * 0.6),
        canvas.height * (0.15 + Math.random() * 0.4)
      );
    }, i * 400);
  }
  // More bursts
  for (let i = 5; i < 12; i++) {
    setTimeout(() => {
      createBurst(
        canvas.width * (0.1 + Math.random() * 0.8),
        canvas.height * (0.1 + Math.random() * 0.5)
      );
    }, i * 350);
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.vy += p.gravity;
      p.vx *= 0.99;
      p.life -= p.decay;
      if (p.life <= 0) {
        particles.splice(i, 1);
        continue;
      }
      ctx.globalAlpha = p.life;
      ctx.fillStyle = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
      ctx.fill();

      // Trail
      ctx.globalAlpha = p.life * 0.3;
      ctx.beginPath();
      ctx.arc(p.x - p.vx, p.y - p.vy, p.size * p.life * 0.6, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    if (particles.length > 0) {
      animFrame = requestAnimationFrame(animate);
    } else {
      canvas.classList.add('hidden');
    }
  }
  animate();

  // Auto-cleanup after 6s
  setTimeout(() => {
    cancelAnimationFrame(animFrame);
    canvas.classList.add('hidden');
    particles.length = 0;
  }, 6000);
}

function showCongrats() {
  document.getElementById('congrats-overlay').classList.remove('hidden');
}

function closeCongrats() {
  document.getElementById('congrats-overlay').classList.add('hidden');
  goMode();
}

// ══════════════════════════════════════
//  UTILITIES
// ══════════════════════════════════════
function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

function normalize(str) {
  return str.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9 ]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

