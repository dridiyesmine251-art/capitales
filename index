<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Capitales du Monde</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #0f0f1a;
    --card: #1a1a2e;
    --card-hover: #22223a;
    --accent: #6c63ff;
    --accent2: #ff6584;
    --accent3: #43e97b;
    --text: #e8e8f0;
    --text-dim: #8888aa;
    --success: #43e97b;
    --error: #ff6584;
    --gold: #ffd700;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Animated background ── */
  body::before {
    content: '';
    position: fixed;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: radial-gradient(ellipse at 30% 20%, rgba(108,99,255,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(255,101,132,0.06) 0%, transparent 50%);
    animation: bgShift 20s ease-in-out infinite alternate;
    z-index: 0;
    pointer-events: none;
  }
  @keyframes bgShift {
    0% { transform: translate(0,0) rotate(0deg); }
    100% { transform: translate(-5%,3%) rotate(3deg); }
  }

  .app {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
    min-height: 100vh;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    padding: 40px 0 20px;
  }
  .header h1 {
    font-size: 2.4rem;
    font-weight: 900;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }
  .header p {
    color: var(--text-dim);
    font-size: 1rem;
  }

  /* ── Breadcrumb / Back ── */
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(108,99,255,0.1);
    border: 1px solid rgba(108,99,255,0.2);
    color: var(--accent);
    padding: 10px 20px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.2s;
    margin-bottom: 24px;
  }
  .back-btn:hover {
    background: rgba(108,99,255,0.2);
    transform: translateX(-3px);
  }

  /* ── Continent grid ── */
  .continent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 16px;
    margin-top: 30px;
  }
  .continent-card {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 28px 24px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .continent-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .continent-card:hover {
    transform: translateY(-4px);
    background: var(--card-hover);
    border-color: rgba(108,99,255,0.3);
    box-shadow: 0 12px 40px rgba(108,99,255,0.15);
  }
  .continent-card:hover::before { opacity: 1; }
  .continent-emoji {
    font-size: 2.8rem;
    margin-bottom: 12px;
    display: block;
  }
  .continent-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .continent-count {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  /* ── Mode selection ── */
  .mode-selection {
    display: flex;
    gap: 16px;
    margin-top: 30px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .mode-card {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 36px 40px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    text-align: center;
    flex: 1;
    max-width: 320px;
    min-width: 220px;
  }
  .mode-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(108,99,255,0.15);
  }
  .mode-card.revise { border-top: 3px solid var(--accent); }
  .mode-card.revise:hover { background: rgba(108,99,255,0.08); }
  .mode-card.test { border-top: 3px solid var(--accent2); }
  .mode-card.test:hover { background: rgba(255,101,132,0.08); }
  .mode-icon { font-size: 2.5rem; margin-bottom: 12px; display: block; }
  .mode-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 6px; }
  .mode-desc { color: var(--text-dim); font-size: 0.9rem; }

  /* ── Flashcard ── */
  .flashcard-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 20px;
  }
  .progress-bar-container {
    width: 100%;
    max-width: 560px;
    margin-bottom: 20px;
  }
  .progress-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent3));
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  .flashcard-container {
    perspective: 1000px;
    width: 100%;
    max-width: 560px;
    height: 320px;
    margin-bottom: 24px;
    cursor: pointer;
  }
  .flashcard {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
    transform-style: preserve-3d;
  }
  .flashcard.flipped {
    transform: rotateY(180deg);
  }
  .flashcard-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .flashcard-front {
    background: linear-gradient(145deg, #1e1e36, #1a1a2e);
  }
  .flashcard-back {
    background: linear-gradient(145deg, #1a2e1e, #162e28);
    transform: rotateY(180deg);
  }
  .flashcard-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-bottom: 16px;
    font-weight: 600;
  }
  .flashcard-text {
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    line-height: 1.3;
  }
  .flashcard-hint {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 20px;
  }

  .flashcard-buttons {
    display: flex;
    gap: 16px;
    width: 100%;
    max-width: 560px;
  }
  .fc-btn {
    flex: 1;
    padding: 16px;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .fc-btn.wrong {
    background: rgba(255,101,132,0.12);
    color: var(--error);
    border: 1px solid rgba(255,101,132,0.25);
  }
  .fc-btn.wrong:hover {
    background: rgba(255,101,132,0.22);
    transform: scale(1.02);
  }
  .fc-btn.correct {
    background: rgba(67,233,123,0.12);
    color: var(--success);
    border: 1px solid rgba(67,233,123,0.25);
  }
  .fc-btn.correct:hover {
    background: rgba(67,233,123,0.22);
    transform: scale(1.02);
  }

  /* ── Round summary ── */
  .round-summary {
    text-align: center;
    max-width: 560px;
    margin: 20px auto;
  }
  .round-summary h2 {
    font-size: 1.6rem;
    margin-bottom: 10px;
  }
  .round-summary p {
    color: var(--text-dim);
    margin-bottom: 20px;
    font-size: 1rem;
  }
  .error-list {
    background: var(--card);
    border-radius: 14px;
    padding: 16px 20px;
    margin-bottom: 20px;
    text-align: left;
  }
  .error-list h3 {
    color: var(--error);
    margin-bottom: 10px;
    font-size: 0.95rem;
  }
  .error-item {
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 0.95rem;
  }
  .error-item:last-child { border-bottom: none; }
  .error-item span.country { color: var(--text-dim); }
  .error-item span.capital { color: var(--accent); font-weight: 600; }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #5a52e0);
    color: #fff;
    padding: 14px 36px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(108,99,255,0.3);
  }

  /* ── Revision Complete ── */
  .revision-complete {
    text-align: center;
    margin-top: 40px;
  }
  .revision-complete .big-emoji { font-size: 4rem; margin-bottom: 16px; display: block; }
  .revision-complete h2 {
    font-size: 1.8rem;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--success), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .revision-complete p { color: var(--text-dim); margin-bottom: 24px; }

  /* ── Test mode ── */
  .test-area {
    max-width: 560px;
    margin: 20px auto;
    text-align: center;
  }
  .test-question-box {
    background: var(--card);
    border-radius: 20px;
    padding: 40px 30px;
    margin-bottom: 24px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .test-question-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-bottom: 16px;
    font-weight: 600;
  }
  .test-country-name {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 4px;
  }
  .test-input-group {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }
  .test-input {
    flex: 1;
    padding: 16px 20px;
    border-radius: 14px;
    border: 2px solid rgba(255,255,255,0.08);
    background: var(--card);
    color: var(--text);
    font-size: 1.1rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    outline: none;
    transition: border-color 0.2s;
  }
  .test-input:focus {
    border-color: var(--accent);
  }
  .test-input.correct-input {
    border-color: var(--success);
    background: rgba(67,233,123,0.06);
  }
  .test-input.wrong-input {
    border-color: var(--error);
    background: rgba(255,101,132,0.06);
  }
  .test-submit {
    padding: 16px 28px;
    border-radius: 14px;
    border: none;
    background: var(--accent);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }
  .test-submit:hover { background: #5a52e0; }
  .test-feedback {
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .test-feedback.correct-fb { color: var(--success); }
  .test-feedback.wrong-fb { color: var(--error); }
  .test-score-bar {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 8px;
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  .test-score-bar span b {
    color: var(--text);
  }

  /* ── Fireworks Canvas ── */
  #fireworksCanvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 9999;
    pointer-events: none;
  }

  /* ── Congrats overlay ── */
  .congrats-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .congrats-box {
    background: rgba(15,15,26,0.95);
    backdrop-filter: blur(20px);
    border: 2px solid var(--gold);
    border-radius: 24px;
    padding: 50px 60px;
    text-align: center;
    pointer-events: auto;
    animation: congratsPop 0.6s cubic-bezier(0.175,0.885,0.32,1.275);
    box-shadow: 0 0 60px rgba(255,215,0,0.3);
  }
  @keyframes congratsPop {
    0% { transform: scale(0.3); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .congrats-box .trophy { font-size: 5rem; display: block; margin-bottom: 16px; }
  .congrats-box h2 {
    font-size: 2.4rem;
    font-weight: 900;
    background: linear-gradient(135deg, var(--gold), #ffaa00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }
  .congrats-box p {
    color: var(--text-dim);
    font-size: 1.1rem;
    margin-bottom: 24px;
  }

  .hidden { display: none !important; }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .header h1 { font-size: 1.7rem; }
    .flashcard-container { height: 260px; }
    .flashcard-text { font-size: 1.5rem; }
    .test-country-name { font-size: 1.6rem; }
    .congrats-box { padding: 30px 24px; margin: 20px; }
    .congrats-box h2 { font-size: 1.8rem; }
    .test-input-group { flex-direction: column; }
  }
</style>
</head>
<body>

<div class="app" id="app">

  <!-- HEADER -->
  <div class="header">
    <h1>🌍 Capitales du Monde</h1>
    <p>Apprends toutes les capitales, continent par continent</p>
  </div>

  <!-- SCREEN: HOME -->
  <div id="screen-home">
    <div class="continent-grid" id="continent-grid"></div>
  </div>

  <!-- SCREEN: MODE SELECTION -->
  <div id="screen-mode" class="hidden">
    <button class="back-btn" onclick="goHome()">← Retour</button>
    <h2 style="text-align:center;font-size:1.5rem;margin-bottom:4px;" id="mode-continent-title"></h2>
    <p style="text-align:center;color:var(--text-dim);font-size:0.9rem;" id="mode-continent-count"></p>
    <div class="mode-selection">
      <div class="mode-card revise" onclick="startRevision()">
        <span class="mode-icon">📚</span>
        <div class="mode-title">Réviser</div>
        <div class="mode-desc">Flashcards style Quizlet — apprends à ton rythme</div>
      </div>
      <div class="mode-card test" onclick="startTest()">
        <span class="mode-icon">✍️</span>
        <div class="mode-title">Test</div>
        <div class="mode-desc">Écris la capitale — zéro erreur pour réussir</div>
      </div>
    </div>
  </div>

  <!-- SCREEN: REVISION -->
  <div id="screen-revision" class="hidden">
    <button class="back-btn" onclick="goMode()">← Retour</button>
    <div class="flashcard-area" id="flashcard-area">
      <div class="progress-bar-container">
        <div class="progress-info">
          <span id="rev-progress-text">1 / 10</span>
          <span id="rev-round-text">Vague 1</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="rev-progress-fill" style="width:0%"></div>
        </div>
      </div>
      <div class="flashcard-container" onclick="flipCard()">
        <div class="flashcard" id="flashcard">
          <div class="flashcard-face flashcard-front">
            <div class="flashcard-label">Pays</div>
            <div class="flashcard-text" id="fc-front-text"></div>
            <div class="flashcard-hint">Clique pour voir la capitale</div>
          </div>
          <div class="flashcard-face flashcard-back">
            <div class="flashcard-label">Capitale</div>
            <div class="flashcard-text" id="fc-back-text"></div>
          </div>
        </div>
      </div>
      <div class="flashcard-buttons" id="fc-buttons" style="visibility:hidden;">
        <button class="fc-btn wrong" onclick="markWrong()">✗ Je ne savais pas</button>
        <button class="fc-btn correct" onclick="markCorrect()">✓ Je savais</button>
      </div>
    </div>

    <!-- Round summary -->
    <div id="round-summary" class="hidden">
      <div class="round-summary">
        <h2 id="round-summary-title"></h2>
        <p id="round-summary-desc"></p>
        <div class="error-list hidden" id="round-error-list">
          <h3>❌ À revoir :</h3>
          <div id="round-error-items"></div>
        </div>
        <button class="btn-primary" id="round-next-btn" onclick="nextRound()"></button>
      </div>
    </div>

    <!-- Revision complete -->
    <div id="revision-complete" class="hidden">
      <div class="revision-complete">
        <span class="big-emoji">🎉</span>
        <h2>Révision terminée !</h2>
        <p>Tu connais toutes les capitales de ce continent.</p>
        <button class="btn-primary" onclick="goMode()" style="margin-right:10px;">Rejouer</button>
        <button class="btn-primary" onclick="goHome()" style="background:linear-gradient(135deg,var(--accent2),#e0527a);">Accueil</button>
      </div>
    </div>
  </div>

  <!-- SCREEN: TEST -->
  <div id="screen-test" class="hidden">
    <button class="back-btn" onclick="goMode()">← Retour</button>
    <div class="test-area">
      <div class="progress-bar-container">
        <div class="progress-info">
          <span id="test-progress-text">0 / 10</span>
          <span id="test-remaining-text"></span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="test-progress-fill" style="width:0%"></div>
        </div>
      </div>
      <div class="test-question-box">
        <div class="test-question-label">Quelle est la capitale de…</div>
        <div class="test-country-name" id="test-country-name"></div>
      </div>
      <div class="test-input-group">
        <input class="test-input" id="test-input" type="text" placeholder="Tape la capitale…" autocomplete="off" />
        <button class="test-submit" id="test-submit-btn" onclick="submitTestAnswer()">OK</button>
      </div>
      <div class="test-feedback" id="test-feedback"></div>
      <div class="test-score-bar">
        <span>✓ <b id="test-correct-count">0</b></span>
        <span>✗ <b id="test-wrong-count">0</b></span>
        <span>Restant: <b id="test-left-count">0</b></span>
      </div>
    </div>
  </div>

</div>

<!-- Fireworks canvas -->
<canvas id="fireworksCanvas" class="hidden"></canvas>

<!-- Congrats overlay -->
<div class="congrats-overlay hidden" id="congrats-overlay">
  <div class="congrats-box">
    <span class="trophy">🏆</span>
    <h2>FÉLICITATIONS !</h2>
    <p>Tu as réussi toutes les capitales sans erreur !</p>
    <button class="btn-primary" onclick="closeCongrats()" style="background:linear-gradient(135deg,var(--gold),#ffaa00);color:#000;">Continuer 🎉</button>
  </div>
</div>

<script>
// ══════════════════════════════════════
//  DATA — All countries & capitals
// ══════════════════════════════════════
const DATA = {
  "Europe": [
    ["Albanie","Tirana"],["Allemagne","Berlin"],["Andorre","Andorre-la-Vieille"],
    ["Autriche","Vienne"],["Belgique","Bruxelles"],["Biélorussie","Minsk"],
    ["Bosnie-Herzégovine","Sarajevo"],["Bulgarie","Sofia"],["Chypre","Nicosie"],
    ["Croatie","Zagreb"],["Danemark","Copenhague"],["Espagne","Madrid"],
    ["Estonie","Tallinn"],["Finlande","Helsinki"],["France","Paris"],
    ["Grèce","Athènes"],["Hongrie","Budapest"],["Irlande","Dublin"],
    ["Islande","Reykjavik"],["Italie","Rome"],["Kosovo","Pristina"],
    ["Lettonie","Riga"],["Liechtenstein","Vaduz"],["Lituanie","Vilnius"],
    ["Luxembourg","Luxembourg"],["Macédoine du Nord","Skopje"],["Malte","La Valette"],
    ["Moldavie","Chișinău"],["Monaco","Monaco"],["Monténégro","Podgorica"],
    ["Norvège","Oslo"],["Pays-Bas","Amsterdam"],["Pologne","Varsovie"],
    ["Portugal","Lisbonne"],["République tchèque","Prague"],["Roumanie","Bucarest"],
    ["Royaume-Uni","Londres"],["Russie","Moscou"],["Saint-Marin","Saint-Marin"],
    ["Serbie","Belgrade"],["Slovaquie","Bratislava"],["Slovénie","Ljubljana"],
    ["Suède","Stockholm"],["Suisse","Berne"],["Ukraine","Kiev"],
    ["Vatican","Vatican"]
  ],
  "Amérique": [
    ["Argentine","Buenos Aires"],["Belize","Belmopan"],["Bolivie","Sucre"],
    ["Brésil","Brasília"],["Canada","Ottawa"],["Chili","Santiago"],
    ["Colombie","Bogota"],["Costa Rica","San José"],["Cuba","La Havane"],
